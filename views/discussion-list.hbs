<div class="toolbar px-3 px-lg-6 pt-3 pb-3">
  <div class="position-relative container-fluid px-0">
    <div class="row align-items-center position-relative">
      <div class="col-sm-7 mb-3 mb-sm-0">
        <h3 class="mb-2 fw-normal">Discussion</h3>
        <div class="d-flex align-items-center gap-2">
          <a href="/discussion"
             class="btn btn-sm {{#if isTop}}btn-primary{{else}}btn-outline-secondary{{/if}}">
            Top
          </a>
          <a href="/discussion/new"
             class="btn btn-sm {{#if isNew}}btn-primary{{else}}btn-outline-secondary{{/if}}">
            New
          </a>
        </div>
      </div>
      <div class="col-sm-5 text-sm-end">
        <a href="/discussion/submit" class="btn btn-sm btn-primary">
          <span class="material-symbols-rounded align-middle me-1 fs-5">add</span>Submit
        </a>
      </div>
    </div>
  </div>
</div>

<div class="content px-3 px-lg-6 pt-3 pb-0 d-flex flex-column-fluid position-relative">
  <div class="container-fluid px-0">
    {{#if notice}}<div class="alert alert-success py-2">{{notice}}</div>{{/if}}
    {{#if error}}<div class="alert alert-danger py-2">{{error}}</div>{{/if}}

    <div class="card">
      <ol class="list-group list-group-flush">
        {{#each items}}
          <li class="list-group-item py-3">
            <div class="d-flex align-items-start">
              <div class="text-body-tertiary me-3 pt-1" style="min-width: 2rem; text-align: right;">{{rank}}.</div>
              <div class="me-3 pt-1">
                {{#if isAuthor}}
                  <span class="material-symbols-rounded text-body-tertiary" title="Your post">arrow_drop_up</span>
                {{else if isDeleted}}
                  <span class="material-symbols-rounded text-body-tertiary">arrow_drop_up</span>
                {{else}}
                  <form action="/discussion/item/{{id}}/upvote" method="post" class="m-0">
                    <input type="hidden" name="back" value="/discussion{{#if ../isNew}}/new{{/if}}?page={{../page}}">
                    <button type="submit"
                            class="btn btn-link p-0 lh-1 {{#if hasUpvoted}}text-primary{{else}}text-body-secondary{{/if}}"
                            title="{{#if hasUpvoted}}Remove upvote{{else}}Upvote{{/if}}">
                      <span class="material-symbols-rounded">arrow_drop_up</span>
                    </button>
                  </form>
                {{/if}}
              </div>
              <div class="flex-grow-1">
                <div class="d-flex flex-wrap align-items-baseline">
                  {{#if isDeleted}}
                    <span class="text-body-tertiary">{{title}}</span>
                  {{else if url}}
                    <a href="{{href}}" rel="noopener noreferrer" target="_blank" class="link-body-emphasis">{{title}}</a>
                  {{else}}
                    <a href="{{itemUrl}}" class="link-body-emphasis">{{title}}</a>
                  {{/if}}
                  {{#if domain}}
                    <small class="ms-2 text-body-tertiary">({{domain}})</small>
                  {{/if}}
                </div>
                <small class="text-body-secondary">
                  {{score}} points by {{authorUsername}} · {{ageRelative}}
                  · <a href="{{itemUrl}}" class="text-body-secondary">{{commentCount}} comments</a>
                </small>
              </div>
            </div>
          </li>
        {{else}}
          <li class="list-group-item py-5 text-center text-body-secondary">
            Nothing here yet. <a href="/discussion/submit">Submit the first post.</a>
          </li>
        {{/each}}
      </ol>
    </div>

    {{#if hasMore}}
      <div class="mt-3">
        <a class="btn btn-outline-secondary btn-sm"
           href="{{#if isNew}}/discussion/new{{else}}/discussion{{/if}}?page={{nextPage}}">
          More
        </a>
      </div>
    {{/if}}
  </div>
</div>
