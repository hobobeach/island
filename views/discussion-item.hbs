<div class="toolbar px-3 px-lg-6 pt-3 pb-3">
  <div class="position-relative container-fluid px-0">
    <div class="row align-items-center position-relative">
      <div class="col-12">
        <a href="/discussion" class="small text-body-secondary text-decoration-none">
          <span class="material-symbols-rounded align-middle fs-6">arrow_back</span> Back to Discussion
        </a>
      </div>
    </div>
  </div>
</div>

<div class="content px-3 px-lg-6 pt-3 pb-0 d-flex flex-column-fluid position-relative">
  <div class="container-fluid px-0">
    {{#if notice}}<div class="alert alert-success py-2">{{notice}}</div>{{/if}}
    {{#if error}}<div class="alert alert-danger py-2">{{error}}</div>{{/if}}

    <div class="card mb-3">
      <div class="card-body">
        <div class="d-flex align-items-start">
          <div class="me-3 pt-1">
            {{#if post.isAuthor}}
              <span class="material-symbols-rounded text-body-tertiary" title="Your post">arrow_drop_up</span>
            {{else if post.isDeleted}}
              <span class="material-symbols-rounded text-body-tertiary">arrow_drop_up</span>
            {{else}}
              <form action="/discussion/item/{{post.id}}/upvote" method="post" class="m-0">
                <input type="hidden" name="back" value="/discussion/item/{{post.id}}">
                <button type="submit"
                        class="btn btn-link p-0 lh-1 {{#if post.hasUpvoted}}text-primary{{else}}text-body-secondary{{/if}}"
                        title="{{#if post.hasUpvoted}}Remove upvote{{else}}Upvote{{/if}}">
                  <span class="material-symbols-rounded">arrow_drop_up</span>
                </button>
              </form>
            {{/if}}
          </div>
          <div class="flex-grow-1">
            <h4 class="mb-1">
              {{#if post.isDeleted}}
                <span class="text-body-tertiary">{{post.title}}</span>
              {{else if post.url}}
                <a href="{{post.url}}" rel="noopener noreferrer" target="_blank" class="link-body-emphasis">{{post.title}}</a>
              {{else}}
                <span>{{post.title}}</span>
              {{/if}}
              {{#if post.domain}}
                <small class="ms-2 text-body-tertiary fw-normal">({{post.domain}})</small>
              {{/if}}
            </h4>
            <small class="text-body-secondary">
              {{post.score}} points by {{post.authorUsername}} · {{post.ageRelative}}
              · {{post.commentCount}} comments
              {{#if post.canEdit}}
                · <a href="/discussion/item/{{post.id}}/edit" class="text-body-secondary">edit</a>
                · <form action="/discussion/item/{{post.id}}/delete" method="post" class="d-inline">
                    <button type="submit" class="btn btn-link p-0 align-baseline text-body-secondary text-decoration-underline"
                            onclick="return confirm('Delete this post?');">delete</button>
                  </form>
              {{/if}}
            </small>
            {{#if post.bodyHtml}}
              <div class="mt-3 small">{{{post.bodyHtml}}}</div>
            {{/if}}
          </div>
        </div>
      </div>
    </div>

    {{#unless post.isDeleted}}
      <div class="card mb-4">
        <div class="card-body">
          <form action="/discussion/item/{{post.id}}/comment" method="post" class="m-0">
            <div class="mb-2">
              <label for="reply-body" class="form-label small text-body-secondary">Add a comment</label>
              <textarea class="form-control" id="reply-body" name="body" rows="4" maxlength="8000" required></textarea>
            </div>
            <button type="submit" class="btn btn-primary btn-sm">Post comment</button>
          </form>
        </div>
      </div>
    {{/unless}}

    {{#each comments}}
      <div class="card mb-2" style="margin-left: {{indentPx}}px;">
        <div class="card-body py-2 px-3">
          <div class="d-flex align-items-start">
            <div class="me-2 pt-1">
              {{#if isAuthor}}
                <span class="material-symbols-rounded text-body-tertiary fs-6" title="Your comment">arrow_drop_up</span>
              {{else if isDeleted}}
                <span class="material-symbols-rounded text-body-tertiary fs-6">arrow_drop_up</span>
              {{else}}
                <form action="/discussion/comment/{{id}}/upvote" method="post" class="m-0">
                  <input type="hidden" name="back" value="/discussion/item/{{../post.id}}">
                  <button type="submit"
                          class="btn btn-link p-0 lh-1 {{#if hasUpvoted}}text-primary{{else}}text-body-secondary{{/if}}"
                          title="{{#if hasUpvoted}}Remove upvote{{else}}Upvote{{/if}}">
                    <span class="material-symbols-rounded fs-6">arrow_drop_up</span>
                  </button>
                </form>
              {{/if}}
            </div>
            <div class="flex-grow-1">
              <div class="small text-body-secondary">
                <strong>{{authorUsername}}</strong> · {{score}} points · {{ageRelative}}
                {{#unless isDeleted}}
                  · <a href="/discussion/comment/{{id}}/reply" class="text-body-secondary">reply</a>
                  {{#if canEdit}}
                    · <a href="/discussion/comment/{{id}}/edit" class="text-body-secondary">edit</a>
                    · <form action="/discussion/comment/{{id}}/delete" method="post" class="d-inline">
                        <button type="submit" class="btn btn-link p-0 align-baseline text-body-secondary text-decoration-underline"
                                onclick="return confirm('Delete this comment?');">delete</button>
                      </form>
                  {{/if}}
                {{/unless}}
              </div>
              <div class="mt-1 small">{{{bodyHtml}}}</div>
            </div>
          </div>
        </div>
      </div>
    {{/each}}
  </div>
</div>
