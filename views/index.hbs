<style>
  :root {
    --sky-top: #1a1033;
    --sky-mid: #6b2d5c;
    --sky-low: #d96b3a;
    --sky-bot: #f3a953;
    --sun: #ffd27a;
    --sun-glow: #ff7a3a;
    --water: #6fb3c9;
    --horizon: #f8e9c8;
    --ink: #f8e9c8;
    --ink-dim: rgba(248, 233, 200, 0.7);
  }

  * { box-sizing: border-box; }

  html, body {
    margin: 0;
    min-height: 100vh;
    font-family: ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
    color: var(--ink);
    background: linear-gradient(
      180deg,
      var(--sky-top) 0%,
      var(--sky-mid) 35%,
      var(--sky-low) 65%,
      var(--sky-bot) 90%
    );
  }

  main {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 1.75rem;
    padding: 2rem 1rem;
    text-align: center;
  }

  h1 {
    margin: 0;
    font-size: clamp(1.75rem, 4vw, 2.75rem);
    font-weight: 600;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    text-shadow: 0 0 18px rgba(255, 122, 58, 0.45);
  }

  .tagline {
    margin: 0;
    max-width: 42rem;
    color: var(--ink-dim);
    font-size: clamp(0.85rem, 1.6vw, 1rem);
    line-height: 1.5;
  }

  pre.art {
    margin: 0;
    padding: 1rem 1.25rem;
    font-size: clamp(0.5rem, 1.2vw, 0.85rem);
    line-height: 1.15;
    color: var(--horizon);
    text-shadow: 0 0 12px rgba(255, 210, 122, 0.35);
    white-space: pre;
    overflow-x: auto;
    max-width: 100%;
    text-align: center;
  }

  pre.art .sun     { color: var(--sun); text-shadow: 0 0 14px var(--sun-glow); }
  pre.art .glare   { color: var(--sun-glow); text-shadow: 0 0 16px var(--sun-glow); }
  pre.art .water   { color: var(--water); }
  pre.art .peak    { color: var(--ink); }
  pre.art .horizon { color: var(--horizon); }

  a.gh {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.65rem 1.1rem;
    border: 1px solid rgba(248, 233, 200, 0.55);
    border-radius: 999px;
    color: var(--ink);
    text-decoration: none;
    font-size: 0.9rem;
    letter-spacing: 0.05em;
    backdrop-filter: blur(4px);
    transition: background 120ms ease, border-color 120ms ease, transform 120ms ease;
  }

  a.gh:hover {
    background: rgba(248, 233, 200, 0.12);
    border-color: var(--ink);
    transform: translateY(-1px);
  }

  a.gh svg { width: 1.1em; height: 1.1em; fill: currentColor; }

  footer {
    margin-top: 0.5rem;
    font-size: 0.75rem;
    color: var(--ink-dim);
    letter-spacing: 0.08em;
  }
</style>

<main>
  <h1>Express Base</h1>
  <p class="tagline">A TypeScript Express starter — auth, TypeORM, Helmet, rate limiting, Zod, and Pino, ready to go.</p>

