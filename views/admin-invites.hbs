<!--//Page Toolbar//-->
<div class="toolbar px-3 px-lg-6 pt-3 pb-3">
  <div class="position-relative container-fluid px-0">
    <div class="row align-items-center position-relative">
      <div class="col-sm-7 mb-3 mb-sm-0">
        <h3 class="mb-2 fw-normal">Invite Requests</h3>
        <p class="mb-0">{{ pendingCount }} pending &middot; {{ totalCount }} total</p>
      </div>
    </div>
  </div>
</div>
<!--//Page Toolbar End//-->

<!--//Page content//-->
<div class="content px-3 px-lg-6 pt-3 pb-0 d-flex flex-column-fluid position-relative">
  <div class="container-fluid px-0">
    <div class="card overflow-hidden">
      <div class="card-body p-0">
        {{#if requests.length}}
        <div class="table-responsive">
          <table class="table table-hover align-middle mb-0">
            <thead>
              <tr>
                <th class="ps-3 ps-lg-6">Name</th>
                <th>Email</th>
                <th>IP Address</th>
                <th>User Agent</th>
                <th>Referrer</th>
                <th>Requested</th>
                <th class="pe-3 pe-lg-6">Status</th>
              </tr>
            </thead>
            <tbody>
              {{#each requests}}
              <tr>
                <td class="ps-3 ps-lg-6 fw-semibold">{{ fullName }}</td>
                <td>{{ email }}</td>
                <td><span class="font-monospace small">{{ ip }}</span></td>
                <td class="small text-body-secondary text-truncate" style="max-width: 220px;" title="{{ userAgent }}">{{ userAgent }}</td>
                <td class="small text-body-secondary text-truncate" style="max-width: 160px;" title="{{ referer }}">{{ referer }}</td>
                <td class="small text-body-secondary text-nowrap">{{ requestedAt }}</td>
                <td class="pe-3 pe-lg-6"><span class="badge text-bg-{{ statusClass }}">{{ statusLabel }}</span></td>
              </tr>
              {{/each}}
            </tbody>
          </table>
        </div>
        {{else}}
        <div class="text-center text-body-secondary py-6">
          <span class="material-symbols-rounded fs-1 d-block mb-2 opacity-50">inbox</span>
          No invite requests yet.
        </div>
        {{/if}}
      </div>
    </div>
  </div>
</div>
<!--//Page content End//-->
