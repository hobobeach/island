<!--Page toolbar-->
<div class="toolbar px-3 px-lg-6 pt-3 pb-3">
  <div class="position-relative container-fluid px-0">
    <div class="row align-items-center position-relative">
      <div class="col-12">
        <h3 class="mb-2 fw-normal">Welcome back, <strong>{{ fullName }}</strong></h3>
        <p class="mb-0 text-body-secondary">Your Island dashboard.</p>
      </div>
    </div>
  </div>
</div>

<!--Page content-->
<div class="content px-3 px-lg-6 pt-3 pb-0 d-flex flex-column-fluid position-relative">
  <div class="container-fluid px-0">
    <div class="row">

      <!--Membership status-->
      <div class="col-xl-6 col-md-6 mb-3">
        <div class="card h-100">
          <div class="card-header d-flex align-items-center">
            <h5 class="mb-0 card-title flex-grow-1">Membership</h5>
            {{#if hasPaid}}
            <span class="badge bg-success-subtle text-success">Active</span>
            {{else}}
            <span class="badge bg-warning-subtle text-warning">Unpaid</span>
            {{/if}}
          </div>
          <div class="card-body">
            <div class="d-flex align-items-center mb-3">
              <span class="size-40 me-3 rounded bg-primary-subtle text-primary d-flex align-items-center justify-content-center flex-shrink-0">
                <span class="material-symbols-rounded">badge</span>
              </span>
              <div>
                <p class="mb-0 small text-body-secondary">Username</p>
                <p class="mb-0 fw-semibold">@{{ username }}</p>
              </div>
            </div>
            <div class="d-flex align-items-center mb-3">
              <span class="size-40 me-3 rounded bg-primary-subtle text-primary d-flex align-items-center justify-content-center flex-shrink-0">
                <span class="material-symbols-rounded">calendar_month</span>
              </span>
              <div>
                <p class="mb-0 small text-body-secondary">Joined</p>
                <p class="mb-0 fw-semibold">{{ joinedAt }}</p>
              </div>
            </div>
            {{#if paidAt}}
            <div class="d-flex align-items-center">
              <span class="size-40 me-3 rounded bg-success-subtle text-success d-flex align-items-center justify-content-center flex-shrink-0">
                <span class="material-symbols-rounded">paid</span>
              </span>
              <div>
                <p class="mb-0 small text-body-secondary">Paid member since</p>
                <p class="mb-0 fw-semibold">{{ paidAt }}</p>
              </div>
            </div>
            {{/if}}
          </div>
        </div>
      </div>

      <!--Karma-->
      <div class="col-xl-3 col-md-6 mb-3">
        <div class="card h-100">
          <div class="card-header">
            <h5 class="mb-0 card-title">Karma</h5>
          </div>
          <div class="card-body d-flex flex-column align-items-center justify-content-center text-center py-5">
            <span class="size-50 mb-3 rounded-circle bg-warning-subtle text-warning d-flex align-items-center justify-content-center">
              <span class="material-symbols-rounded fs-2">star</span>
            </span>
            <h3 class="mb-0">{{ karma }}</h3>
            <p class="mb-0 text-body-secondary small mt-1">net upvotes from other members</p>
          </div>
        </div>
      </div>

      <!--Activity stub-->
      <div class="col-xl-3 col-md-6 mb-3">
        <div class="card h-100">
          <div class="card-header">
            <h5 class="mb-0 card-title">Activity</h5>
          </div>
          <div class="card-body d-flex flex-column align-items-center justify-content-center text-center py-5">
            <span class="size-50 mb-3 rounded-circle bg-body-secondary text-body-tertiary d-flex align-items-center justify-content-center">
              <span class="material-symbols-rounded fs-2">timeline</span>
            </span>
            <p class="mb-0 text-body-secondary small">Nothing here yet.</p>
          </div>
        </div>
      </div>

      <!--Community stub-->
      <div class="col-xl-3 col-md-6 mb-3">
        <div class="card h-100">
          <div class="card-header">
            <h5 class="mb-0 card-title">Community</h5>
          </div>
          <div class="card-body d-flex flex-column align-items-center justify-content-center text-center py-5">
            <span class="size-50 mb-3 rounded-circle bg-body-secondary text-body-tertiary d-flex align-items-center justify-content-center">
              <span class="material-symbols-rounded fs-2">group</span>
            </span>
            <p class="mb-0 text-body-secondary small">Coming soon.</p>
          </div>
        </div>
      </div>

    </div>
  </div>
</div>
